
@model ChangSpaBeauty.Application.DTOs.UserRegisterDTO
@{
    ViewData["Title"] = "Đăng ký";
}
@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" />
}

<div class="auth-container">
    <div class="auth-card auth-card-wide">
        <span class="kb-sparkle" style="top:14px;right:20px;animation-duration:4.5s;">✨</span>
        <span class="kb-sparkle" style="bottom:18px;left:16px;font-size:14px;animation-duration:5.5s;">🌸</span>

        <div class="auth-header">
            <div class="auth-logo"><i class="fas fa-spa"></i></div>
            <h2>Đăng ký tài khoản</h2>
            <p>Tham gia ChangSpaBeauTy để trải nghiệm mua sắm tuyệt vời</p>
        </div>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            @* ── HÀNG 1: Họ tên + Email ── *@
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Name">Họ và tên</label>
                    <div class="input-icon-wrap">
                        <i class="fas fa-user form-icon"></i>
                        <input asp-for="Name" class="form-control" placeholder="Nhập họ tên đầy đủ" />
                    </div>
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email">Email</label>
                    <div class="input-icon-wrap">
                        <i class="fas fa-envelope form-icon"></i>
                        <input asp-for="Email" class="form-control" placeholder="Nhập email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>

            @* ── HÀNG 2: SĐT + Địa chỉ ── *@
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Phone">Số điện thoại</label>
                    <div class="input-icon-wrap">
                        <i class="fas fa-phone form-icon"></i>
                        <input asp-for="Phone" class="form-control" placeholder="Tuỳ chọn" />
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Address">Địa chỉ</label>
                    <div class="input-icon-wrap">
                        <i class="fas fa-map-marker-alt form-icon"></i>
                        <input asp-for="Address" class="form-control" placeholder="Tuỳ chọn" />
                    </div>
                </div>
            </div>

            @* ── HÀNG 3: Mật khẩu + Xác nhận ── *@
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Password">Mật khẩu</label>
                    <div class="input-icon-wrap">
                        <i class="fas fa-lock form-icon"></i>
                        <div class="input-password">
                            <input asp-for="Password" class="form-control"
                                   placeholder="Tối thiểu 6 ký tự" id="passwordInput" />
                            <button type="button" class="btn-toggle-password"
                                    onclick="togglePassword('passwordInput','eyeIcon1')">
                                <i class="fas fa-eye" id="eyeIcon1"></i>
                            </button>
                        </div>
                    </div>
                    <div class="pwd-strength" id="pwdStrength" style="display:none;">
                        <div class="pwd-strength-bar">
                            <div class="pwd-strength-fill" id="pwdStrengthFill"></div>
                        </div>
                        <span class="pwd-strength-label" id="pwdStrengthLabel"></span>
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword">Xác nhận mật khẩu</label>
                    <div class="input-icon-wrap">
                        <i class="fas fa-lock form-icon"></i>
                        <div class="input-password">
                            <input asp-for="ConfirmPassword" class="form-control"
                                   placeholder="Nhập lại mật khẩu" id="confirmInput" />
                            <button type="button" class="btn-toggle-password"
                                    onclick="togglePassword('confirmInput','eyeIcon2')">
                                <i class="fas fa-eye" id="eyeIcon2"></i>
                            </button>
                        </div>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
            </div>

            <button type="submit" class="btn-auth">
                <i class="fas fa-user-plus"></i> Đăng ký
            </button>
        </form>

        <div class="auth-footer">
            <p>Đã có tài khoản? <a asp-action="Login">Đăng nhập</a></p>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/register.js" asp-append-version="true"></script>
}
