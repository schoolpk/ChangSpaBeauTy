@model ChangSpaBeauty.Application.DTOs.Order.OrderDto
@{
    ViewData["Title"] = "Đặt hàng thành công";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/success.css" asp-append-version="true" />
}

<canvas class="sc-confetti" id="confetti-canvas"></canvas>

<div class="sc-wrap">

    @* HERO *@
    <div class="sc-hero">
        <div class="sc-checkmark">
            <svg class="sc-check-svg" viewBox="0 0 52 52">
                <circle class="sc-check-circle" cx="26" cy="26" r="25" fill="none"/>
                <path class="sc-check-tick" fill="none" d="M14 27l8 8 16-16"/>
            </svg>
        </div>
        <h1 class="sc-title">Đặt hàng thành công!</h1>
        <p class="sc-sub">Cảm ơn bạn đã tin tưởng ChangSpaBeauTy 🌸</p>
        <div class="sc-order-id">
            Mã đơn hàng <strong>#@Model.OrderId</strong>
        </div>
    </div>

    <div class="sc-body">

        @* DELIVERY INFO *@
        <div class="sc-card">
            <div class="sc-card-title">📦 Thông tin giao hàng</div>
            <div class="sc-info-grid">
                <div>
                    <div class="sc-info-label">Trạng thái</div>
                    <div class="sc-info-value">
                        <span class="sc-badge status-@Model.Status">
                            @(Model.Status switch {
                                "pending"   => "⏳ Chờ xác nhận",
                                "confirmed" => "✅ Đã xác nhận",
                                "shipping"  => "🚚 Đang giao",
                                "done"      => "✔️ Hoàn thành",
                                "cancelled" => "❌ Đã hủy",
                                _           => Model.Status
                            })
                        </span>
                    </div>
                </div>
                <div>
                    <div class="sc-info-label">Ngày đặt</div>
                    <div class="sc-info-value">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                <div>
                    <div class="sc-info-label">Số điện thoại</div>
                    <div class="sc-info-value">@Model.Phone</div>
                </div>
                <div class="sc-info-full">
                    <div class="sc-info-label">Địa chỉ nhận hàng</div>
                    <div class="sc-info-value">@Model.Address</div>
                </div>
            </div>
        </div>

        @* ORDER ITEMS *@
        <div class="sc-card">
            <div class="sc-card-title">🛍️ Sản phẩm đã đặt</div>
            <div class="sc-item-list">
                @foreach (var item in Model.Items)
                {
                    <div class="sc-item">
                        <div class="sc-item-img">
                            <img src="~/images/products/@item.ProductImage"
                                 alt="@item.ProductName"
                                 onerror="this.src='/images/placeholder.png'" />
                        </div>
                        <div class="sc-item-info">
                            <div class="sc-item-name">@item.ProductName</div>
                            <div class="sc-item-meta">
                                @item.UnitPrice.ToString("N0") ₫ × @item.Quantity
                            </div>
                        </div>
                        <div class="sc-item-price">@item.Subtotal.ToString("N0") ₫</div>
                    </div>
                }
            </div>
            <div class="sc-total-row">
                <span>Tổng thanh toán</span>
                <span class="sc-total">@Model.TotalPrice.ToString("N0") ₫</span>
            </div>
        </div>

        @* TIMELINE *@
        <div class="sc-card sc-timeline-card">
            <div class="sc-card-title">🗓️ Tiếp theo</div>
            <div class="sc-timeline">
                <div class="sc-tl-step">
                    <div class="sc-tl-icon">📩</div>
                    <div class="sc-tl-content">
                        <div class="sc-tl-title">Xác nhận đơn hàng</div>
                        <div class="sc-tl-desc">Chúng tôi đang kiểm tra và xác nhận đơn hàng của bạn</div>
                    </div>
                </div>
                <div class="sc-tl-step">
                    <div class="sc-tl-icon">📦</div>
                    <div class="sc-tl-content">
                        <div class="sc-tl-title">Đóng gói & vận chuyển</div>
                        <div class="sc-tl-desc">Sản phẩm sẽ được đóng gói cẩn thận và giao cho đơn vị vận chuyển</div>
                    </div>
                </div>
                <div class="sc-tl-step">
                    <div class="sc-tl-icon">🚚</div>
                    <div class="sc-tl-content">
                        <div class="sc-tl-title">Giao hàng đến bạn</div>
                        <div class="sc-tl-desc">Shipper sẽ liên hệ trước khi giao. Vui lòng chuẩn bị tiền mặt (COD)</div>
                    </div>
                </div>
            </div>
        </div>

        @* ACTIONS *@
        <div class="sc-actions">
            <a asp-controller="Home" asp-action="Index" class="sc-btn sc-btn-ghost">
                🏠 Về trang chủ
            </a>
            <a asp-controller="Products" asp-action="Index" class="sc-btn sc-btn-secondary">
                🛒 Tiếp tục mua sắm
            </a>
            <a asp-controller="Order" asp-action="MyOrders" class="sc-btn sc-btn-primary">
                📦 Xem đơn hàng của tôi
            </a>
        </div>

    </div>
</div>

@section Scripts {
<script>
    const canvas = document.getElementById('confetti-canvas');
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    const pieces = Array.from({length: 80}, () => ({
        x: Math.random() * canvas.width,
        y: Math.random() * -canvas.height,
        r: Math.random() * 6 + 3,
        c: ['#D6336C','#FF7FA8','#FFB6C1','#fce4ec','#e85d8a'][Math.floor(Math.random()*5)],
        v: Math.random() * 2 + 1,
        a: Math.random() * Math.PI * 2
    }));
    let frame = 0;
    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        pieces.forEach(p => {
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
            ctx.fillStyle = p.c;
            ctx.fill();
            p.y += p.v;
            p.x += Math.sin(p.a + frame * 0.02) * 0.8;
            if (p.y > canvas.height) { p.y = -10; p.x = Math.random() * canvas.width; }
        });
        frame++;
        if (frame < 180) requestAnimationFrame(draw);
        else ctx.clearRect(0, 0, canvas.width, canvas.height);
    }
    draw();
</script>
}