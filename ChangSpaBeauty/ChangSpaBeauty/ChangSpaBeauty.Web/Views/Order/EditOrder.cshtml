
@model ChangSpaBeauty.Application.DTOs.Order.OrderDto
@{
    ViewData["Title"] = "Sửa đơn hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/checkout.css" asp-append-version="true" />
}

<div class="co-wrap">
    <h1 style="font-size:1.4rem;font-weight:700;margin-bottom:1.5rem;">
        ✏️ Sửa đơn hàng #@Model.OrderId
    </h1>

    @if (TempData["Error"] != null)
    {
        <div class="co-alert co-alert-error">
            <span class="co-alert-icon">❌</span> @TempData["Error"]
        </div>
    }

    <form asp-controller="Order" asp-action="EditOrder" method="post" id="edit-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="OrderId" value="@Model.OrderId" />

        @* ── THÔNG TIN GIAO HÀNG ── *@
        <div class="co-form-card">
            <div class="co-card-title">
                <span class="co-card-icon">📦</span> Thông tin giao hàng
            </div>

            <div class="co-field">
                <label class="co-label">Số điện thoại <span class="co-req">*</span></label>
                <div class="co-input-wrap">
                    <span class="co-input-icon">📞</span>
                    <input name="Phone" type="tel" value="@Model.Phone" required />
                </div>
            </div>

            <div class="co-field">
                <label class="co-label">Địa chỉ giao hàng <span class="co-req">*</span></label>
                <div class="co-textarea-wrap">
                    <span class="co-textarea-icon">📍</span>
                    <textarea name="Address" required>@Model.Address</textarea>
                </div>
            </div>
        </div>

        @* ── SẢN PHẨM TRONG ĐƠN ── *@
        <div class="co-summary-card" style="margin-top:1.2rem;">
            <div class="co-card-title">
                <span class="co-card-icon">🛍️</span> Sản phẩm trong đơn
            </div>

            <div class="co-item-list" id="item-list">
                @for (int i = 0; i < Model.Items.Count; i++)
                {
                    var item = Model.Items[i];
                    <div class="co-item" id="item-row-@i" style="position:relative;">
                        <div class="co-item-img-wrap">
                            <img src="~/images/products/@item.ProductImage"
                                 alt="@item.ProductName"
                                 onerror="this.src='/images/placeholder.png'" />
                        </div>
                        <div class="co-item-info">
                            <div class="co-item-name">@item.ProductName</div>
                            <div class="co-item-unit">@item.UnitPrice.ToString("N0") ₫ / sản phẩm</div>
                        </div>

                        <input type="hidden" class="item-product-id" name="Items[@i].ProductId" value="@item.ProductId" />

                        @* Số lượng *@
                        <div style="display:flex;align-items:center;gap:.4rem;">
                            <button type="button" onclick="changeQty(@i, -1)"
                                    style="width:28px;height:28px;border-radius:50%;border:1.5px solid #FFB6C1;
                                               background:#FFF5F8;color:#D6336C;font-size:1rem;cursor:pointer;
                                               display:flex;align-items:center;justify-content:center;">
                                −
                            </button>
                            <input type="number" name="Items[@i].Quantity" id="qty-@i"
                                   value="@item.Quantity" min="1"
                                   style="width:55px;padding:.3rem;border:1.5px solid #e8e8e8;
                                              border-radius:8px;text-align:center;" />
                            <button type="button" onclick="changeQty(@i, 1)"
                                    style="width:28px;height:28px;border-radius:50%;border:1.5px solid #FFB6C1;
                                               background:#FFF5F8;color:#D6336C;font-size:1rem;cursor:pointer;
                                               display:flex;align-items:center;justify-content:center;">
                                +
                            </button>
                        </div>

                        @* Nút xóa sản phẩm *@
                        <button type="button" onclick="removeItem(@i)"
                                title="Xóa sản phẩm khỏi đơn"
                                style="width:28px;height:28px;border-radius:50%;border:1.5px solid #f5c6c6;
                                           background:#fff0f0;color:#dc3545;font-size:.9rem;cursor:pointer;
                                           display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            ✕
                        </button>
                    </div>
                }
            </div>

            <hr class="co-divider" />

            @* ── ACTIONS ── *@
            <div style="display:flex;flex-direction:column;gap:.7rem;margin-top:.5rem;">
                <button type="submit" class="co-btn-order">
                    💾 Lưu thay đổi
                </button>

                @* Nút hủy đơn hàng *@
                <button type="button"
                        onclick="confirmCancel(@Model.OrderId)"
                        style="width:100%;padding:.85rem;background:#fff;color:#dc3545;
                               border:1.5px solid #dc3545;border-radius:12px;font-size:.95rem;
                               font-weight:700;cursor:pointer;transition:all .2s;">
                    🗑️ Hủy đơn hàng
                </button>

                <a asp-action="MyOrders" class="co-btn-back">← Quay lại đơn hàng của tôi</a>
            </div>
        </div>
    </form>

    @* Form hủy đơn ẩn *@
    <form id="cancel-form" asp-controller="Order" asp-action="CancelOrder" method="post" style="display:none">
        @Html.AntiForgeryToken()
        <input type="hidden" name="orderId" value="@Model.OrderId" />
    </form>
</div>

@section Scripts {
    <script src="~/js/editorder.js" asp-append-version="true"></script>
}
