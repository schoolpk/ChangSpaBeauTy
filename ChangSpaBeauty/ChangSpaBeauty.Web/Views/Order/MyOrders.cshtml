
@model List<ChangSpaBeauty.Application.DTOs.Order.OrderDto>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var selectedStatus = ViewBag.SelectedStatus as string ?? "all";

}

@section Styles {
    <link rel="stylesheet" href="~/css/myorders.css" asp-append-version="true">
}

<div class="mo-wrap">
    <div class="mo-header">
        <div>
            <h1 class="mo-title">📦 Đơn hàng của tôi</h1>
            <p class="mo-subtitle">Theo dõi và quản lý đơn hàng của bạn</p>
        </div>
        <a asp-controller="Products" asp-action="Index" class="mo-btn-shop">🛍️ Mua thêm</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mo-alert mo-alert-success">✅ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mo-alert mo-alert-error">❌ @TempData["Error"]</div>
    }


    @* ── TABS LỌC THEO TRẠNG THÁI ── *@
    <div class="mo-tabs">
        <a asp-action="MyOrders" asp-route-status=""
           class="mo-tab @(selectedStatus == "all" ? "active" : "")">
            Tất cả
        </a>
        <a asp-action="MyOrders" asp-route-status="pending"
           class="mo-tab @(selectedStatus == "pending" ? "active" : "")">
            ⏳ Chờ xác nhận
        </a>
        <a asp-action="MyOrders" asp-route-status="confirmed"
           class="mo-tab @(selectedStatus == "confirmed" ? "active" : "")">
            ✅ Đã xác nhận
        </a>
        <a asp-action="MyOrders" asp-route-status="shipping"
           class="mo-tab @(selectedStatus == "shipping" ? "active" : "")">
            🚚 Đang giao
        </a>
        <a asp-action="MyOrders" asp-route-status="done"
           class="mo-tab @(selectedStatus == "done" ? "active" : "")">
            ✔️ Hoàn thành
        </a>
        <a asp-action="MyOrders" asp-route-status="cancelled"
           class="mo-tab @(selectedStatus == "cancelled" ? "active" : "")">
            ❌ Đã hủy
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="mo-empty">
            <div class="mo-empty-icon">📭</div>

            <h3>Không có đơn hàng nào</h3>
            <p>
                @if (selectedStatus != "all")
                {
                    <span>Không có đơn hàng nào ở trạng thái này.</span>
                }
                else
                {
                    <span>Hãy khám phá các sản phẩm và đặt hàng ngay!</span>
                }
            </p>
            <a asp-controller="Products" asp-action="Index" class="mo-btn-shop-big">
                Mua sắm ngay →
            </a>
        </div>
    }
    else
    {
        <div class="mo-list">
            @foreach (var order in Model)
            {
                <div class="mo-card">
                    @* Header *@
                    <div class="mo-card-header">
                        <div class="mo-card-header-left">
                            <span class="mo-order-id">Đơn hàng #@order.OrderId</span>
                            <span class="mo-order-date">
                                @order.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </span>
                        </div>
                        <span class="mo-badge status-@order.Status">
                            @(order.Status switch {
                                "pending"   => "⏳ Chờ xác nhận",
                                "confirmed" => "✅ Đã xác nhận",
                                "shipping"  => "🚚 Đang giao",
                                "done"      => "✔️ Hoàn thành",
                                "cancelled" => "❌ Đã hủy",
                                _           => order.Status
                            })
                        </span>
                    </div>

                    @* Progress bar *@
                    @if (order.Status != "cancelled")
                    {
                        var steps = new[] { "pending", "confirmed", "shipping", "done" };
                        var labels = new[] { "Chờ xác nhận", "Đã xác nhận", "Đang giao", "Hoàn thành" };
                        var icons  = new[] { "⏳", "✅", "🚚", "✔️" };
                        var currentIdx = Array.IndexOf(steps, order.Status);

                        <div class="mo-progress">
                            @for (int i = 0; i < steps.Length; i++)
                            {
                                var done = i <= currentIdx ? "done" : "";
                                <div class="mo-progress-step @done">
                                    <div class="mo-progress-dot">@icons[i]</div>
                                    <span>@labels[i]</span>
                                </div>
                                @if (i < steps.Length - 1)
                                {
                                    <div class="mo-progress-line @done"></div>
                                }
                            }
                        </div>
                    }

                    @* Items *@
                    <div class="mo-items">
                        @foreach (var item in order.Items.Take(2))
                        {
                            <div class="mo-item">
                                <img src="~/images/products/@item.ProductImage"
                                     alt="@item.ProductName"
                                     onerror="this.src='/images/placeholder.png'" />
                                <div class="mo-item-info">
                                    <div class="mo-item-name">@item.ProductName</div>
                                    <div class="mo-item-meta">
                                        @item.UnitPrice.ToString("N0") ₫ × @item.Quantity
                                    </div>
                                </div>

                                <div class="mo-item-sub">@item.Subtotal.ToString("N0") ₫</div>
                            </div>
                        }
                        @if (order.Items.Count > 2)
                        {
                            <div class="mo-more-items">+@(order.Items.Count - 2) sản phẩm khác</div>
                        }
                    </div>

                    @* Footer *@
                    <div class="mo-card-footer">
                        <div class="mo-footer-left">
                            <div class="mo-address">📍 @order.Address</div>
                            <div class="mo-phone">📞 @order.Phone</div>
                        </div>
                        <div class="mo-footer-right">
                            <div class="mo-total-label">Tổng tiền</div>
                            <div class="mo-total">@order.TotalPrice.ToString("N0") ₫</div>

                            @if (order.Status == "pending" || order.Status == "confirmed")
                            {
                                <form asp-controller="Order" asp-action="CancelOrder" method="post"
                                      onsubmit="return confirm('Bạn chắc chắn muốn hủy đơn hàng #@order.OrderId?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="orderId" value="@order.OrderId" />
                                    <button type="submit" class="mo-btn-cancel">🗑️ Hủy đơn hàng</button>
                                </form>
                            }
                            else if (order.Status == "done" || order.Status == "shipping")
                            {
                                <span class="mo-cancel-locked">🔒 Không thể hủy</span>
                            }

                            @if(order.Status == "pending")
                            {
                                <a asp-action="EditOrder" asp-route-id="@order.OrderId" class="mo-btn-cancel"
                                   style="submit">
                                    ✏️ Sửa đơn hàng
                                </a>
                            }
                            else if (order.Status == "done" || order.Status == "shipping")
                            {
                                <span class="mo-cancel-locked">🔒 Không thể sửa</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
