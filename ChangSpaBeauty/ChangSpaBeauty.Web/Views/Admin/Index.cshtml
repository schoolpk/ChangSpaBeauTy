@using ChangSpaBeauty.Domain.Entities
@using ChangSpaBeauty.Application.DTOs
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/changspa.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
    <link rel="stylesheet" href="~/css/create.css" />
}

<div class="admin-topbar">
    <span class="admin-topbar-title">✦ ChangSpaBeauTy — Admin</span>
    <div class="admin-topbar-right">
        <span class="admin-topbar-badge">Xin chào, @(User.Identity?.Name ?? "Admin")</span>
    </div>
</div>

  <div class="create-page">
        @if(TempData["Success"] != null)
          {
              <div class="alert alert-success">
                  ✅ @TempData["Success"]
              </div>
          }
  </div>
<div class="admin-wrap">

    @* ===== STATS ===== *@
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">👥 Người dùng</div>
            <div class="stat-value">@ViewBag.TotalUsers</div>
            <div class="stat-sub">+@ViewBag.NewUsersThisMonth mới tháng này</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">📦 Sản phẩm</div>
            <div class="stat-value">@ViewBag.TotalProducts</div>
            <div class="stat-sub">Đang kinh doanh</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">🗂️ Danh mục</div>
            <div class="stat-value">@ViewBag.TotalCategories</div>
            <div class="stat-sub">Đang hoạt động</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">🛒 Đơn hàng</div>
            <div class="stat-value">@ViewBag.TotalOrders</div>
            <div class="stat-sub">Tổng cộng</div>
        </div>
    </div>
    <div class="admin-tab-nav">
        <button class="tab active" onclick="switchTab('users', this)">👥 Người dùng</button>
        <button class="tab" onclick="switchTab('products', this)">📦 Sản phẩm</button>
        <button class="tab" onclick="switchTab('categories', this)">🗂️ Danh mục</button>
        <button class="tab" onclick="switchTab('orders', this)">🛒 Đơn hàng</button>
    </div>

    @* ===== PANEL: NGƯỜI DÙNG ===== *@
    <div id="panel-users" class="admin-panel active">
        <div class="admin-card">
            <div class="admin-toolbar">
                <div class="admin-search-wrap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                    <input type="text" placeholder="Tìm kiếm theo tên hoặc email..."
                           oninput="filterTable('tbl-users', this.value)" />
                </div>
            </div>
            <table class="admin-table" id="tbl-users">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên</th>
                        <th>Email</th>
                        <th>Điện thoại</th>
                        <th>Địa chỉ</th>
                        <th>Vai trò</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.Users != null)
                    {
                        @foreach (var user in ViewBag.Users)
                        {
                            <tr>
                                <td class="id-cell">#@user.Id</td>
                                <td>
                                    <div class="user-cell">
                                        <span class="avatar">@(user.Name?.Length > 0 ? user.Name.Substring(0, 1).ToUpper() : "?")</span>
                                        @user.Name
                                    </div>
                                </td>
                                <td>@user.Email</td>
                                <td>@user.Phone</td>
                                <td>@user.Address</td>
                                <td>
                                    <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
                                        @* Nút đổi role *@
                                        <form asp-controller="Admin" asp-action="ChangeRole" method="post"
                                              onsubmit="return confirm('Đổi vai trò của @user.Name?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@user.Id" />
                                            @if (user.Role == "Admin")
                                            {
                                                <button type="submit" class="btn-role btn-role-to-customer"
                                                        title="Hạ xuống Customer">
                                                    👤Admin → Customer
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn-role btn-role-to-admin"
                                                        title="Nâng lên Admin">
                                                    🔑 Customer → Admin
                                                </button>
                                            }
                                        </form>
                                    </div>
                                </td>
                                <td>
                                    <form asp-controller="Admin" asp-action="DeleteUser" method="post" 
                                          onsubmit="return confirm('Xóa user này?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn-delete">Xóa</button>
                                    </form>
                                </td>
                            </tr>

                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="empty-state">Không có dữ liệu người dùng</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* ===== PANEL: SẢN PHẨM ===== *@
    <div id="panel-products" class="admin-panel">
        <div class="admin-card">
            <div class="admin-toolbar">
                <div class="admin-search-wrap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                    <input type="text" placeholder="Tìm kiếm sản phẩm..."
                           oninput="filterTable('tbl-products', this.value)" />
                </div>
                <a  asp-action="CreateProduct" class="btn-add">+ Thêm sản phẩm</a>
            </div>
            <table class="admin-table" id="tbl-products">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên sản phẩm</th>
                        <th>Giá</th>
                        <th>Danh mục</th>
                        <th>Đã bán</th>
                        <th>Tồn kho</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.Products != null)
                    {
                        @foreach (var pro in ViewBag.Products)
                        {
                            <tr>
                                <td class="id-cell">#@pro.ProductId</td>
                                <td>
                                    <div class="prod-cell">
                                        <div class="img-thumb">
                                            @if (!string.IsNullOrEmpty(pro.Image))
                                            {
                                                <img src="~/images/products/@pro.Image"
                                                 alt="@pro.Name"
                                                 onerror="this.src='/images/placeholder.png'"
                                                 style="width:100%;height:100%;object-fit:cover;" />
                                            }
                                            else
                                            {
                                                <span>🌸</span>
                                            }
                                        </div>
                                        @pro.Name
                                    </div>
                                </td>
                                <td class="price">@pro.Price.ToString("N0") ₫</td>
                                <td><span class="badge badge-cat">@pro.CategoryName</span></td>
                                <td>@pro.Sold</td>
                                <td>
                                    @if (pro.Stock <= 0)
                                    {
                                        <span style="color:#dc3545;font-weight:600;">Hết hàng</span>
                                    }
                                    else
                                    {
                                        <span style="color:#2e7d32;font-weight:600;">@pro.Stock</span>
                                    }
                                </td>
                                <td>
                                    <div class="action-group">
                                        <a asp-action="EditProduct"
                                           asp-route-id="@pro.ProductId" class="btn-edit">Sửa</a>
                                        <form asp-action="DeleteProduct" method="post" style="margin:0;"
                                              onsubmit="return confirm('Xóa danh mục \'@pro.Name\?'\nCó chắc: muốn xóa sản phẩm)">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@pro.ProductId" />
                                            <button type="submit" class="btn-delete">🗑 Xóa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="empty-state">Không có dữ liệu sản phẩm</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* ===== PANEL: DANH MỤC ===== *@
    <div id="panel-categories" class="admin-panel">
        <div class="admin-card">
            <div class="admin-toolbar">
                <div class="admin-search-wrap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                    <input type="text" placeholder="Tìm kiếm danh mục..."
                           oninput="filterTable('tbl-categories', this.value)" />
                </div>
                <a  asp-action="CreateCategory" class="btn-add">+ Thêm danh mục</a>
            </div>
            <table class="admin-table" id="tbl-categories">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên danh mục</th>
                        <th>Thương hiệu</th>
                        <th>Số sản phẩm</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.Categories != null)
                    {
                        @foreach (var cat in ViewBag.Categories)
                        {
                            <tr>
                                <td class="id-cell">#@cat.CategoryId</td>
                                <td><span class="cat-chip">🏷️ @cat.Name</span></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(cat.Trademark))
                                    {
                                        @foreach (var tm in cat.Trademark.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                        {
                                            <span style="display:inline-block;background:#FFF0F5;color:#D6336C;
                                                         border:1px solid #FFB6C1;border-radius:20px;
                                                         padding:2px 10px;font-size:.75rem;font-weight:600;
                                                         margin:2px;">
                                                💄 @tm.Trim()
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span style="color:#ccc;font-size:.8rem;">—</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge-count">@(cat.Products?.Count ?? 0)</span>
                                </td>
                                <td>
                                    <div class="action-group">
                                        <a asp-action="EditCategory"
                                           asp-route-id="@cat.CategoryId" class="btn-edit">Sửa</a>
                                        <form asp-action="DeleteCategory" method="post" style="margin:0;"
                                              onsubmit="return confirm('Xóa danh mục \'@cat.Name\'?\nLưu ý: không thể xóa nếu còn sản phẩm!')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@cat.CategoryId" />
                                            <button type="submit" class="btn-delete">🗑 Xóa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="empty-state">Không có dữ liệu danh mục</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @* ===== PANEL: ĐƠN HÀNG ===== *@
    <div id="panel-orders" class="admin-panel">
        <div class="admin-card">
            <div class="admin-toolbar">
                <div class="admin-search-wrap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                    <input type="text" placeholder="Tìm kiếm đơn hàng..."
                           oninput="filterTable('tbl-orders', this.value)" />
                </div>
            </div>
            @* ── FILTER TABS THEO TRẠNG THÁI ── *@
            <div style="display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:1rem;">
                <button class="order-filter-tab active" onclick="filterOrders('all', this)">
                    Tất cả
                </button>
                <button class="order-filter-tab" onclick="filterOrders('pending', this)">
                    ⏳ Chờ xác nhận
                </button>
                <button class="order-filter-tab" onclick="filterOrders('confirmed', this)">
                    ✅ Đã xác nhận
                </button>
                <button class="order-filter-tab" onclick="filterOrders('shipping', this)">
                    🚚 Đang giao
                </button>
                <button class="order-filter-tab" onclick="filterOrders('done', this)">
                    ✔️ Hoàn thành
                </button>
                <button class="order-filter-tab" onclick="filterOrders('cancelled', this)">
                    ❌ Đã hủy
                </button>
            </div>
            <table class="admin-table" id="tbl-orders">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Đơn hàng</th>
                        <th>SP</th>
                        <th>Số lượng SP</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Ngày đặt</th>
                        <th>Xác nhận</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.Orders != null)
                    {
                        @foreach (var ord in ViewBag.Orders)
                        {
                            <tr data-status="@ord.Status">
                                <td>#@ord.OrderId</td>
                                <td>
                                    <div style="font-weight:600">@ord.User?.Name</div>
                                    <div style="font-size:.82rem;color:#888">@ord.User?.Email</div>
                                    <div style="font-size:.82rem;color:#888">@ord.Address</div>
                                    <div style="font-size:.82rem;color:#888">📞 @ord.Phone</div>
                                </td>
                                <td>@ord.OrderDetails?.Count</td>
                                <td>
                                    @{
                                        var details = ord.OrderDetails as IEnumerable<ChangSpaBeauty.Domain.Entities.OrderDetail>;
                                        var totalQty = details?.Sum(od => od.Quantity) ?? 0;
                                    }
                                    @totalQty
                                </td>
                                <td style="font-weight:700;color:var(--pink-dark)">
                                    @(((decimal)ord.TotalPrice).ToString("N0")) ₫
                                </td>
                                <td>
                                    <span class="badge-status status-@ord.Status">
                                        @(ord.Status switch {
                                            "pending"   => "⏳ Chờ xác nhận",
                                            "confirmed" => "✅ Đã xác nhận",
                                            "shipping"  => "🚚 Đang giao",
                                            "done"      => "✔️ Hoàn thành",
                                            "cancelled" => "❌ Đã hủy",
                                            _           => ord.Status
                                        })
                                    </span>
                                </td>
                                <td>@ord.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @{
                                        string ordStatus = ord.Status?.ToString() ?? "pending";
                                        var lockedStatuses = new[] { "cancelled", "done"};
                                        bool isLocked = lockedStatuses.Contains(ordStatus);
                                    }

                                    @if (isLocked)
                                    {
                                        <span style="font-size:.82rem;color:#999;font-weight:600;">
                                            🔒 Không thể thay đổi
                                        </span>
                                    }
                                    else
                                    {
                                        <form asp-controller="Admin" asp-action="UpdateOrderStatus"
                                              method="post" style="display:flex;gap:.4rem;align-items:center">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="orderId" value="@ord.OrderId" />
                                            @{
                                                var statusOptions = new[]
                                                {
                                                    ("pending",   "⏳ Chờ xác nhận"),
                                                    ("confirmed", "✅ Xác nhận"),
                                                    ("shipping",  "🚚 Giao hàng"),
                                                    ("done",      "✔️ Hoàn thành"),
                                                    ("cancelled", "❌ Hủy")
                                                };
                                                var selectHtml = "<select name='status' class='status-select'>";
                                                foreach (var (val, label) in statusOptions)
                                                {
                                                    var sel = ordStatus == val ? " selected" : "";
                                                    selectHtml += $"<option value='{val}'{sel}>{label}</option>";
                                                }
                                                selectHtml += "</select>";
                                            }
                                            @Html.Raw(selectHtml)
                                            <button type="submit" class="btn-status-save">Lưu</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="empty-state">Không có dữ liệu đơn hàng</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>@* end admin-wrap *@

@section Scripts {
    <script src="~/js/admin.js" asp-append-version="true"></script>
}
