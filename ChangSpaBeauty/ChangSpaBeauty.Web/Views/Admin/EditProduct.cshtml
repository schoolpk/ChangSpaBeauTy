@model ChangSpaBeauty.Web.ViewModels.Product.ProductCreateViewModel
@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
    int proId = (int)ViewBag.ProductId;
    string? currentImage = ViewBag.CurrentImage as string;
    int currentStock = (int)(ViewBag.CurrentStock ?? 0); // ← thêm
}
@section Styles {
    <link rel="stylesheet" href="~/css/edit.css" />
}

<div class="admin-page">

    <div class="admin-breadcrumb">
        <a asp-controller="Home" asp-action="Index">Trang chủ</a>
        <span>›</span>
        <a asp-controller="Admin" asp-action="Products">Sản phẩm</a>
        <span>›</span>
        <span style="color:#D6336C;">Chỉnh sửa</span>
    </div>

    <div class="admin-title">✏️ Chỉnh sửa sản phẩm</div>
    <div class="edit-badge">ID: #@proId</div>

    <div class="admin-card">
        <div class="card-section-title">📋 Thông tin sản phẩm</div>

        <form asp-action="EditProduct" asp-route-id="@proId"
              method="post" enctype="multipart/form-data"
              id="editForm" novalidate>
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label" asp-for="Name">
                    Tên sản phẩm <span class="req">*</span>
                </label>
                <input asp-for="Name" class="form-control" id="nameInput"
                       placeholder="Tên sản phẩm" maxlength="100" />
                <div class="char-count"><span id="nameCount">0</span>/100</div>
                <span asp-validation-for="Name" class="text-danger"></span>

                <label class="form-label" asp-for="Price">
                    Giá <span class="req">*</span>
                </label>
                <input asp-for="Price" class="form-control"
                       placeholder="Giá sản phẩm" />
                <span asp-validation-for="Price" class="text-danger"></span>

                <label class="form-label" asp-for="CategoryId">
                    Danh mục <span class="req">*</span>
                </label>
                <select asp-for="CategoryId" class="form-control"
                        asp-items="ViewBag.Categories">
                    <option value="">-- Chọn danh mục --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>

                <label class="form-label" asp-for="Description">Mô tả</label>
                <input asp-for="Description" class="form-control"
                       placeholder="Mô tả" maxlength="100" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            @* ── TỒN KHO ── *@
            <div class="form-group" style="margin-top:1.2rem;">
                <div class="card-section-title">📦 Tồn kho</div>

                @* Hiển thị tồn kho hiện tại *@
                <div style="display:flex;align-items:center;gap:1rem;
                            background:#FFF5F8;border:1px solid #FFB6C1;
                            border-radius:10px;padding:.8rem 1rem;margin-bottom:1rem;">
                    <span style="font-size:1.4rem;">📦</span>
                    <div>
                        <div style="font-size:.78rem;color:#888;">Tồn kho hiện tại</div>
                        @if (currentStock <= 0)
                        {
                            <div style="font-size:1.1rem;font-weight:700;color:#dc3545;">
                                Hết hàng (0)
                            </div>
                        }
                        else
                        {
                            <div style="font-size:1.1rem;font-weight:700;color:#2e7d32;">
                                @currentStock sản phẩm
                            </div>
                        }
                    </div>
                </div>

                <label class="form-label" asp-for="Stock">
                    Cập nhật tồn kho <span class="req">*</span>
                </label>
                <div style="display:flex;align-items:center;gap:.5rem;">
                    <button type="button" onclick="changeStock(-1)"
                            style="width:36px;height:36px;border-radius:50%;
                                   border:1.5px solid #FFB6C1;background:#FFF5F8;
                                   color:#D6336C;font-size:1.2rem;cursor:pointer;
                                   display:flex;align-items:center;justify-content:center;">
                        −
                    </button>
                    <input asp-for="Stock" class="form-control" id="stockInput"
                           type="number" min="0" style="width:100px;text-align:center;" />
                    <button type="button" onclick="changeStock(1)"
                            style="width:36px;height:36px;border-radius:50%;
                                   border:1.5px solid #FFB6C1;background:#FFF5F8;
                                   color:#D6336C;font-size:1.2rem;cursor:pointer;
                                   display:flex;align-items:center;justify-content:center;">
                        +
                    </button>
                    <span style="font-size:.82rem;color:#888;">sản phẩm</span>
                </div>
                <span asp-validation-for="Stock" class="text-danger"></span>

                @* Quick set buttons *@
                <div style="display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.6rem;">
                    <span style="font-size:.78rem;color:#aaa;align-self:center;">Đặt nhanh:</span>
                    @foreach (var qty in new[] { 10, 20, 50, 100 })
                    {
                        <button type="button" onclick="setStock(@qty)"
                                style="padding:.25rem .7rem;border:1.5px solid #FFB6C1;
                                           border-radius:20px;background:#fff;color:#D6336C;
                                           font-size:.75rem;font-weight:600;cursor:pointer;">
                            +@qty
                        </button>
                    }
                </div>
            </div>

            @* ── ẢNH SẢN PHẨM ── *@
            <div class="form-group" style="margin-top:1.2rem;">
                <div class="card-section-title">🖼️ Ảnh sản phẩm</div>

                <div style="margin-bottom:1rem;">
                    <div style="font-size:.82rem;color:#888;margin-bottom:.5rem;">Ảnh hiện tại:</div>
                    <div id="img-preview-wrap" style="width:140px;height:140px;border-radius:12px;
                         border:2px dashed #FFB6C1;overflow:hidden;background:#FFF5F8;
                         display:flex;align-items:center;justify-content:center;">
                        @if (!string.IsNullOrEmpty(currentImage))
                        {
                            <img id="img-preview"
                                 src="~/images/products/@currentImage"
                                 alt="Ảnh hiện tại"
                                 style="width:100%;height:100%;object-fit:cover;" />
                        }
                        else
                        {
                            <span id="img-placeholder" style="font-size:2.5rem;">🧴</span>
                        }
                    </div>
                </div>

                <label class="form-label" asp-for="ImageFile">
                    Thay ảnh mới <span style="color:#888;font-weight:400;">(để trống nếu không đổi)</span>
                </label>
                <input asp-for="ImageFile" type="file"
                       accept=".jpg,.jpeg,.png,.webp,.gif"
                       class="form-control" id="imageFileInput"
                       onchange="previewImage(this)" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
                <div style="font-size:.78rem;color:#aaa;margin-top:.3rem;">
                    Chấp nhận: JPG, PNG, WebP, GIF · Tối đa 5MB
                </div>
            </div>

            <div class="btn-row">
                <a asp-action="Index" class="btn-cancel">Hủy bỏ</a>
                <button type="submit" class="btn-save" id="saveBtn">
                    <span class="spinner" id="spinner"></span>
                    <span id="saveLabel">💾 Lưu thay đổi</span>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/edit.js" asp-append-version="true"></script>
}