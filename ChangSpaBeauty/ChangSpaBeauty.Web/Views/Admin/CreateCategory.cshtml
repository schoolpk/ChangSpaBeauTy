@model ChangSpaBeauty.Web.ViewModels.CategoryCreateViewModel
@{
    ViewData["Title"] = "Thêm danh mục mới";
    Layout = "_Layout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/create.css" />
}
<div class="create-page">
    <div class="create-header">
        <a asp-controller="Admin" asp-action="Index">← Quay lại</a>
        <span style="color:#ccc">|</span>
        <h1>✨ Thêm danh mục mới</h1>
    </div>
    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger">
            ⚠️ Vui lòng kiểm tra lại thông tin bên dưới.
        </div>
    }

    <div class="create-card">
        <form asp-controller="Admin" asp-action="CreateCategory" method="post"
              enctype="multipart/form-data" id="createForm" novalidate>
            @Html.AntiForgeryToken()

            <div class="form-section">
                <div class="form-section-title">Thông tin cơ bản</div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Name">Tên danh mục<span class="required">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="VD: Kem dưỡng da, Son môi...">
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="TradeMark">Tên thương hiệu<span class="required">*</span></label>
                        <input asp-for="TradeMark" class="form-control" placeholder="VD: L'Oréal, Cocoon...">
                        <span asp-validation-for="TradeMark" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="btn-row">
                <a asp-controller="Admin" asp-action="Index" class="btn-cancel">Hủy</a>
                <button type="submit" class="btn-submit" id="submitBtn">
                    <span class="spinner" id="spinner"></span>
                    💾 Lưu danh mục
                </button>
            </div>
        </form>
    </div>
</div>
@section Scripts{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/createt.js" asp-append-version="true"></script>
}
