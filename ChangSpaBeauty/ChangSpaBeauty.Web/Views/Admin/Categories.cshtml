@model IEnumerable<ChangSpaBeauty.Domain.Entities.Category>
@{
    ViewData["Title"] = "Quản lý danh mục";
}
@section Styles {
    <link rel="stylesheet" href="~/css/category.css" />
}
<div class="admin-page">

    <div class="admin-breadcrumb">
        <a asp-controller="Home" asp-action="Index">Trang chủ</a>
        <span>›</span>
        <a asp-controller="Admin" asp-action="Index">Admin</a>
        <span>›</span>
        <span style="color:#D6336C;">Danh mục</span>
    </div>

    <div class="page-header">
        <div class="page-title">🗂️ Quản lý danh mục</div>
        <a  asp-action="CreateCategory" class="btn-add">＋ Thêm danh mục</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">✅ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">⚠️ @TempData["Error"]</div>
    }

    <div class="admin-card">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">📂</div>
                <p>Chưa có danh mục nào. 
                    <a asp-controller="Categories" asp-action="CreateCategory" style="color:#D6336C;">Thêm ngay →</a></p>
            </div>
        }
        else
        {
            <table class="cat-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Tên danh mục</th>
                        <th>Thương Hiệu</th>
                        <th>Số sản phẩm</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int stt = 1;
                    }
                    @foreach (var cat in Model)
                    {
                        <tr>
                            <td style="color:#bbb; width:40px;">@stt</td>
                            <td style="font-weight:600; color:#2d2d2d;">@cat.Name</td>
                            <td style="color:#888; max-width:280px;">
                                @(string.IsNullOrEmpty(cat.Trademark) ? "—" : cat.Trademark)
                            </td>
                            <td>
                                <span class="badge-count">@(cat.Products?.Count() ?? 0)</span>
                            </td>
                            <td>
                                <div class="action-btns">
                                    <a asp-action="EditCategory" asp-route-id="@cat.CategoryId"
                                       class="btn-edit">✏️ Sửa</a>

                                    <form asp-action="DeleteCategory" method="post" style="margin:0;"
                                          onsubmit="return confirm('Xóa danh mục \'@cat.Name\'?\nLưu ý: không thể xóa nếu còn sản phẩm!')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@cat.CategoryId" />
                                        <button type="submit" class="btn-delete">🗑 Xóa</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        stt++;
                    }
                </tbody>
            </table>
        }
    </div>
</div>
