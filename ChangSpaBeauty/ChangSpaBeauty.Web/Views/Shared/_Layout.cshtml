@using System.Linq
@using ChangSpaBeauty.Domain.Entities
@using System.Security.Claims
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – ChangSpaBeauTy</title>
    <link rel="stylesheet" href="~/css/changspa.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- ── SCROLL PROGRESS ─────────────────────────────── -->
<div class="scroll-progress" id="scrollProgress"></div>

<!-- ══ HEADER ══════════════════════════════════════════ -->
<header id="site-header">

    <!-- Brand bar -->
    <div class="brand-bar">
        <a asp-controller="Home" asp-action="Index" class="brand-link">
            <span class="brand-icon">✦</span>
            <span class="brand-name">ChangSpaBeauTy</span>
            <span class="brand-icon">✦</span>
        </a>
        <div class="brand-tagline">Chăm sóc vẻ đẹp tự nhiên · Thuần chất từ thiên nhiên</div>
    </div>

    <!-- Main header bar -->
    <div class="header-bar">

        <!-- Search -->
        <form asp-controller="Products" asp-action="Index" method="get" class="search-wrap">
            <svg class="search-icon" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <input type="text" name="keyword" placeholder="Tìm sản phẩm, thương hiệu…"
                   value="@ViewData["Keyword"]" autocomplete="off" />
            <button type="submit" class="search-btn" aria-label="Tìm kiếm">
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
            </button>
        </form>

        <!-- Actions -->
        <div class="header-actions">
            @{
                var notifications = ViewBag.Notifications ?? new List<dynamic>();
                var unreadCount   = ViewBag.UnreadCount   ?? 0;
            }

            @if (User.Identity?.IsAuthenticated == true)
            {
                <!-- Greeting + hover dropdown -->
                
                var userEmail = User.FindFirst(ClaimTypes.Email)?.Value;
                var userRoleLabel = User.IsInRole("Admin") ? "Quản trị viên" : "Khách hàng";
                var userInitial = !string.IsNullOrEmpty(User.Identity.Name) ? User.Identity.Name.Trim().Substring(0, 1).ToUpper() : "?";
                
                <div class="user-menu-wrap" tabindex="0">
                    <span class="user-greeting">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                        @User.Identity.Name
                        <svg class="user-caret" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path d="M6 9l6 6 6-6"/>
                        </svg>
                    </span>

                    <div class="user-dropdown" role="menu">
                        <div class="user-dropdown-header">
                            <div class="user-avatar">@userInitial</div>
                            <div class="user-dropdown-info">
                                <div class="user-dropdown-name">@User.Identity.Name</div>
                                <div class="user-dropdown-role">@userRoleLabel</div>
                                @if (!string.IsNullOrEmpty(userEmail))
                                {
                                    <div class="user-dropdown-email">@userEmail</div>
                                }
                            </div>
                        </div>
                        <div class="user-dropdown-body">
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Admin" asp-action="Index" class="user-dropdown-item">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                                        <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
                                    </svg>
                                    Trang quản trị
                                </a>
                            }
                            @if (User.IsInRole("Customer"))
                            {
                                <a asp-controller="Order" asp-action="MyOrders" class="user-dropdown-item">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
                                    </svg>
                                    Đơn hàng của tôi
                                </a>
                            }
                        </div>
                    </div>
                </div>

                @if (User.IsInRole("Customer"))
                {
                    <a asp-controller="Order" asp-action="MyOrders" class="btn btn-ghost">
                        🛒 Đơn hàng của tôi
                    </a>
                }

                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="Index" class="btn btn-ghost">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                            <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
                        </svg>
                        Admin
                    </a>
                }

                <!-- Bell -->
                <div class="notif-wrap">
                    <button class="notif-bell" id="notifBtn" onclick="toggleNotif()" title="Thông báo" aria-label="Thông báo">
                        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                        </svg>
                        @if (unreadCount > 0)
                        {
                            <span class="notif-badge">@(unreadCount > 9 ? "9+" : unreadCount.ToString())</span>
                        }
                    </button>
                        <form id="markread-form" style="display:none">
                            @Html.AntiForgeryToken()
                        </form>
                    <div class="notif-dropdown" id="notif-dropdown" role="menu">
                        <div class="notif-header">
                            <span>
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="vertical-align:-2px;margin-right:5px">
                                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                                    <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                                </svg>
                                Thông báo
                            </span>
                            @if (notifications.Count > 0)
                            {
                                <form asp-controller="Notification" asp-action="ClearAll" method="post" style="margin:0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="notif-clear">Xoá tất cả</button>
                                </form>
                            }
                        </div>
                        <div class="notif-list">
                            @if (notifications.Count > 0)
                            {
                                @foreach (var n in notifications)
                                {
                                    <div class="notif-item @(n.IsRead ? "" : "unread")">
                                        <div class="notif-dot @(n.IsRead ? "" : "active")"></div>
                                        <div class="notif-content">
                                            <div class="notif-msg">@n.Message</div>
                                            <div class="notif-time">@n.CreatedAt.ToString("HH:mm · dd/MM/yyyy")</div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="notif-empty">
                                    <svg width="36" height="36" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="opacity:.3;margin-bottom:8px">
                                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                                        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                                    </svg>
                                    <p>Chưa có thông báo nào</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Cart -->
                @if (User.IsInRole("Customer"))
                {
                    <a asp-controller="Cart" asp-action="Index" class="cart-btn" aria-label="Giỏ hàng" title="Giỏ hàng">
                        <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                            <line x1="3" y1="6" x2="21" y2="6"/>
                            <path d="M16 10a4 4 0 0 1-8 0"/>
                        </svg>
                        @{var cartCount = (int)(ViewData["CartCount"] ?? 0);}
                        @if (cartCount > 0)
                        {
                            <span class="cart-badge">@(cartCount > 9 ? "9+" : cartCount.ToString())</span>
                        }
                    </a>
                }

                <!-- Logout -->
                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;margin:0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-sm">Đăng xuất</button>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-sm">Đăng ký</a>
                <a asp-controller="Account" asp-action="Login" class="btn btn-solid-sm">Đăng nhập</a>
            }
        </div>
    </div>
</header>

<!-- ══ NAV ═════════════════════════════════════════════ -->
    <nav id="site-nav">
        <div class="nav-inner">
            <a asp-controller="Home" asp-action="Index"
               class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                Trang chủ
            </a>

            @{
                var navCategories = ViewBag.NavCategories as IEnumerable<ChangSpaBeauty.Domain.Entities.Category>
                ?? Enumerable.Empty<ChangSpaBeauty.Domain.Entities.Category>();
            }
            @foreach (var cat in navCategories)
            {
                <a asp-controller="Products" asp-action="Index"
                   asp-route-category="@cat.CategoryId"
                   class="nav-item">
                    @cat.Name
                </a>
            }
        </div>
    </nav>

<!-- ══ MAIN ═════════════════════════════════════════════ -->
<main>
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="toast toast-error">@TempData["ErrorMessage"]</div>
        }
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="toast toast-success">@TempData["SuccessMessage"]</div>
        }
    @RenderBody()
</main>

<!-- ══ FOOTER ═══════════════════════════════════════════ -->
<footer>
    <div class="footer-top">
        <div class="footer-inner">

            <!-- Brand col -->
            <div class="footer-brand-col">
                <div class="footer-brand-name">✦ ChangSpaBeauTy</div>
                <p class="footer-desc">Chúng tôi mang đến những sản phẩm làm đẹp cao cấp từ thiên nhiên, giúp bạn toả sáng mỗi ngày. Chất lượng uy tín, an toàn cho mọi loại da.</p>
                <div class="footer-social">
                    <a class="social-btn" title="Facebook"  href="#" aria-label="Facebook">
                        <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                    </a>
                    <a class="social-btn" title="Instagram" href="#" aria-label="Instagram">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
                    </a>
                    <a class="social-btn" title="TikTok"   href="#" aria-label="TikTok">
                        <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.77 1.52V6.75a4.85 4.85 0 0 1-1-.06z"/></svg>
                    </a>
                    <a class="social-btn" title="Zalo"     href="#" aria-label="Zalo">
                        <span style="font-size:10px;font-weight:700;letter-spacing:-.5px">ZL</span>
                    </a>
                </div>
            </div>

            <!-- Sản phẩm -->
            <div>
                <div class="footer-col-title">Sản phẩm</div>
                <a asp-controller="Products" asp-action="Index" asp-route-category="duong-da"       class="footer-link">Dưỡng da</a>
                <a asp-controller="Products" asp-action="Index" asp-route-category="trang-diem"     class="footer-link">Trang điểm</a>
                <a asp-controller="Products" asp-action="Index" asp-route-category="cham-soc-toc"   class="footer-link">Chăm sóc tóc</a>
                <a asp-controller="Products" asp-action="Index" asp-route-category="nuoc-hoa"       class="footer-link">Nước hoa</a>
                <a asp-controller="Products" asp-action="Index" asp-route-category="combo"          class="footer-link">Combo tiết kiệm</a>
            </div>

            <!-- Hỗ trợ -->
            <div>
                <div class="footer-col-title">Hỗ trợ</div>
                <a class="footer-link">Chính sách đổi trả</a>
                <a class="footer-link">Hướng dẫn mua hàng</a>
                <a class="footer-link">Câu hỏi thường gặp</a>
                <a asp-controller="Home" asp-action="Contact" class="footer-link">Liên hệ</a>
            </div>

            <!-- Liên hệ -->
            <div>
                <div class="footer-col-title">Liên hệ</div>
                <span class="footer-link footer-link--icon">
                    <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    Hà Nội, Việt Nam
                </span>
                <span class="footer-link footer-link--icon">
                    <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.06 6.06l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/></svg>
                    0123 456 789
                </span>
                <span class="footer-link footer-link--icon">
                    <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    hello@changspa.vn
                </span>
                <span class="footer-link footer-link--icon">
                    <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
                    8:00 – 21:00 mỗi ngày
                </span>
            </div>

        </div>
    </div>
    <div class="footer-bottom">
        <span>© 2025 ChangSpaBeauTy · Tất cả quyền được bảo lưu</span>
        <span class="footer-bottom-sep">·</span>
        <span>Made with <span style="color:var(--pink-mid)">♥</span> in Việt Nam</span>
    </div>
</footer>

<!-- Back to top -->
<button class="back-top" id="backTop" onclick="scrollToTop()" aria-label="Lên đầu trang" title="Lên đầu trang">
    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path d="M18 15l-6-6-6 6"/>
    </svg>
</button>

<script src="~/js/changspa.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
